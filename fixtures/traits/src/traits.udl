namespace traits {
    Drawable make_circle(f64 radius);
    Drawable make_rect(f64 width, f64 height);
};

[Trait]
interface Drawable {
    string describe();
    f64 area();
};

[Traits=(Display, Eq, Hash)]
dictionary TraitRecord {
  string name;
  u32 value;
};

[Traits=(Display, Eq, Hash)]
enum TraitColor {
  "Red",
  "Green",
  "Blue",
};
